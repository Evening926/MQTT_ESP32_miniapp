/* pages/record_crud/record_crud.wxss */
.head_box{
    display: flex;
    justify-content: center;
    padding-top: 120rpx;
}

.head_box >image{
    height: 80rpx;
    width: 80rpx;
}

.head_box >text{
    margin-left: 15rpx;
    font-size: 38rpx;
    font-weight: 600;
    line-height: 100rpx;
    color: rgb(255, 255, 255);
}

.weather_box{
    background-color: rgb(172, 169, 169);
    height: 320rpx;
    margin: 0rpx 50rpx;
    box-shadow: 0 8rpx 20rpx 0 rgba(170, 161, 161, 0.3);
    border-radius: 32rpx;
}
.title{
    margin-left: 175rpx;
    font-size: 48rpx;
    font-weight: 550;
    line-height: 100rpx;
    color: rgb(46, 43, 43);
}
.picker_box{
    margin-left: 25rpx;
    padding-top: 15rpx;
    font-size: 35rpx;
    color: rgb(0, 0, 0);
}
.picker-font-color{
    margin-left: 50rpx;
    font-size: 35rpx;
    color: rgb(77, 73, 73);
    padding-top: 15rpx;
}
.record_box{
    background-color: rgb(172, 169, 169);
    height: 800rpx;
    margin: 60rpx 50rpx;
    box-shadow: 0 8rpx 20rpx 0 rgba(170, 161, 161, 0.3);
    border-radius: 32rpx;
    
}